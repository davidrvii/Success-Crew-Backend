generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model role {
  role_id    Int      @id @default(autoincrement())
  role_name  String   @db.VarChar
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  users      user[]
}

model office {
  office_id      Int      @id @default(autoincrement())
  office_name    String   @db.VarChar
  office_address String   @db.VarChar
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)
  users          user[]
}

model user {
  user_id         Int             @id @default(autoincrement())
  office_id       Int
  role_id         Int
  user_name       String          @db.VarChar
  user_email      String          @unique @db.VarChar
  user_password   String          @db.VarChar
  user_phone      String?         @db.VarChar
  user_photo      String?         @db.VarChar
  user_birth      DateTime?       @db.Date
  start_work      DateTime?       @db.Date
  end_work        DateTime?       @db.Date
  crew_status     String?         @db.VarChar
  contract_status String?         @db.VarChar
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  updated_at      DateTime        @default(now()) @db.Timestamptz(6)
  attendance      attendance[]
  leave           leave[]
  notification    notification[]
  out_of_office   out_of_office[]
  overtime        overtime[]
  office          office          @relation(fields: [office_id], references: [office_id], onDelete: NoAction, onUpdate: NoAction)
  role            role            @relation(fields: [role_id], references: [role_id], onDelete: NoAction, onUpdate: NoAction)
  visit           visit[]
}

model notification {
  notification_id    Int      @id @default(autoincrement())
  user_id            Int
  notification_title String   @db.VarChar
  notification_desc  String   @db.VarChar
  is_read            Boolean  @default(false)
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @db.Timestamptz(6)
  user               user     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

model attendance {
  attendance_id     Int        @id @default(autoincrement())
  user_id           Int
  attendance_status String     @db.VarChar
  attendance_in     DateTime?  @db.Timestamptz(6)
  attendance_out    DateTime?  @db.Timestamptz(6)
  attendance_date   DateTime   @db.Date
  created_at        DateTime   @default(now()) @db.Timestamptz(6)
  updated_at        DateTime   @default(now()) @db.Timestamptz(6)
  user              user       @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  overtime          overtime[]
}

model overtime {
  overtime_id     Int        @id @default(autoincrement())
  user_id         Int
  attendance_id   Int
  overtime_desc   String     @db.VarChar
  overtime_date   DateTime?  @db.Date
  overtime_start  DateTime   @db.Timestamptz(6)
  overtime_end    DateTime   @db.Timestamptz(6)
  overtime_status String     @db.VarChar
  created_at      DateTime   @default(now()) @db.Timestamptz(6)
  updated_at      DateTime   @default(now()) @db.Timestamptz(6)
  attendance      attendance @relation(fields: [attendance_id], references: [attendance_id], onDelete: Cascade, onUpdate: NoAction)
  user            user       @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

model leave {
  leave_id     Int      @id @default(autoincrement())
  user_id      Int
  leave_desc   String   @db.VarChar
  leave_start  DateTime @db.Date
  leave_end    DateTime @db.Date
  leave_status String   @db.VarChar
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @db.Timestamptz(6)
  user         user     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

model out_of_office {
  out_of_office_id     Int      @id @default(autoincrement())
  user_id              Int
  out_of_office_desc   String   @db.VarChar
  out_of_office_start  DateTime @db.Date
  out_of_office_end    DateTime @db.Date
  out_of_office_status String   @db.VarChar
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @default(now()) @db.Timestamptz(6)
  user                 user     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
}

model visitor {
  visitor_id       Int      @id @default(autoincrement())
  visitor_name     String?  @db.VarChar
  visitor_phone    String?  @db.VarChar
  visitor_company  String?  @db.VarChar
  visitor_category String?  @db.VarChar
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)
  visit            visit[]
}

model visit {
  visit_id         Int             @id @default(autoincrement())
  visitor_id       Int
  user_id          Int
  visit_type       String?         @db.VarChar
  visit_status     String          @db.VarChar
  visitor_interest String          @db.VarChar
  visit_desc       String?         @db.VarChar
  visit_sales      String?         @db.VarChar
  created_at       DateTime        @default(now()) @db.Timestamptz(6)
  updated_at       DateTime        @default(now()) @db.Timestamptz(6)
  follow_up        follow_up[]
  product_sold     product_sold[]
  unit_serviced    unit_serviced[]
  user             user            @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)
  visitor          visitor         @relation(fields: [visitor_id], references: [visitor_id], onDelete: Cascade, onUpdate: NoAction)
}

model follow_up {
  follow_up_id     Int      @id @default(autoincrement())
  visit_id         Int
  follow_up_status String   @db.VarChar
  follow_up_action String   @db.VarChar
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)
  visit            visit    @relation(fields: [visit_id], references: [visit_id], onDelete: Cascade, onUpdate: NoAction)
}

model product_sold {
  product_sold_id       Int      @id @default(autoincrement())
  visit_id              Int
  product_sold_name     String   @db.VarChar
  product_sold_quantity Int?
  product_sold_total    Float?
  product_sold_desc     String?  @db.VarChar
  created_at            DateTime @default(now()) @db.Timestamptz(6)
  updated_at            DateTime @default(now()) @db.Timestamptz(6)
  visit                 visit    @relation(fields: [visit_id], references: [visit_id], onDelete: Cascade, onUpdate: NoAction)
}

model unit_serviced {
  unit_serviced_id     Int      @id @default(autoincrement())
  visit_id             Int
  unit_serviced_name   String   @db.VarChar
  unit_serviced_issue  String?  @db.VarChar
  unit_serviced_action String?  @db.VarChar
  unit_serviced_status String?  @db.VarChar
  unit_serviced_desc   String?  @db.VarChar
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @default(now()) @db.Timestamptz(6)
  visit                visit    @relation(fields: [visit_id], references: [visit_id], onDelete: Cascade, onUpdate: NoAction)
}
